        self.log_text.tag_config("error", foreground="#F87171")

    # ── Widget helpers ────────────────────────────────────────────────────

    def _make_radio(self, parent, text, value, **pack_kw):
        rb = tk.Radiobutton(parent, text=text, variable=self.mode_var,
                             value=value, command=self._on_mode_change,
                             bg=SECTION_BG, fg=TEXT_MAIN,
                             activebackground=SECTION_BG,
                             selectcolor=CARD_BG,
                             font=FONT_BODY, cursor="hand2")
        rb.pack(**pack_kw)

    def _mode_desc(self, mode):
        if mode == "value":
            return ("Any change between OLD and NEW is flagged red. "
                    "Non-changed cells are green. Simple and strict.")
        return ("For numeric cells, calculates (NEW−OLD)/|OLD|×100 and shows the % change. "
                "Text/non-numeric changes are still flagged as 'Value Changed'.")

    def _validate_pct(self, val):
        """Allow empty, digits, and a single decimal point."""
        if val == "":
            return True
        try:
            float(val)
            return True
        except ValueError:
            return val.count(".") <= 1 and all(c.isdigit() or c == "." for c in val)

    # ── Event handlers ────────────────────────────────────────────────────

    def _on_mode_change(self):
        mode = self.mode_var.get()
        self.mode_desc.config(text=self._mode_desc(mode))
        # Dim threshold + override sections when mode is "value"
        state = "normal" if mode == "variance" else "disabled"
        self.thresh_chk.config(state=state)
        self.override_chk.config(state=state)
        if mode == "variance" and self.thresh_enabled.get():
            self.thresh_entry.config(state="normal")
        else:
            self.thresh_entry.config(state="disabled")

    def _on_thresh_toggle(self):
        if self.thresh_enabled.get() and self.mode_var.get() == "variance":
            self.thresh_entry.config(state="normal")
        else:
            self.thresh_entry.config(state="disabled")

    def _check_ready(self):
        both = bool(self.new_zone.get_file() and self.old_zone.get_file())
        self.run_btn.config(state="normal" if both else "disabled",
                             bg=ACCENT if both else "#93C5FD")

    def _clear(self):
        self.new_zone.clear(); self.old_zone.clear()
        self.run_btn.config(state="disabled", bg="#93C5FD")
        self._log("Cleared.", "info")
        self.status_lbl.config(
            text="Ready — select a NEW file and an OLD file to begin", fg=TEXT_SUB)

    def _log(self, msg, tag="info"):
        self.log_text.config(state="normal")
        self.log_text.insert("end", msg + "\n", tag)
        self.log_text.see("end")
        self.log_text.config(state="disabled")

    def _start_comparison(self):
        new_path = self.new_zone.get_file()
        old_path = self.old_zone.get_file()
        if not new_path or not old_path:
            messagebox.showwarning("Missing files", "Please select both NEW and OLD Excel files.")
            return

        mode = self.mode_var.get()
        override_values = (mode == "variance") and self.override_var.get()

        # Resolve threshold
        threshold = None
        if mode == "variance" and self.thresh_enabled.get():
            raw = self.thresh_var.get().strip()
            try:
                threshold = float(raw)
                if threshold < 0:
                    raise ValueError
            except ValueError:
                messagebox.showerror("Invalid threshold",
                                      "Please enter a positive number for the variance threshold.")
                return

        script_dir = os.path.dirname(os.path.abspath(sys.argv[0])) or os.getcwd()
        out_path   = os.path.join(script_dir, "comparison_output.xlsx")

        self.run_btn.config(state="disabled", text="⏳  Running…")
        self.progress.start(12)
        self.status_lbl.config(text="Comparing files…", fg=ACCENT)
        self._log(f"NEW : {new_path}", "info")
        self._log(f"OLD : {old_path}", "info")
        self._log(f"OUT : {out_path}", "info")
        self._log("─" * 55, "info")

        def worker():
            try:
                run_comparison(new_path, old_path, out_path,
                               lambda m: self.after(0, self._log, m, "info"),
                               mode, threshold, override_values)
                self.after(0, self._on_success, out_path)
            except Exception as e:
                self.after(0, self._on_error, str(e))

        threading.Thread(target=worker, daemon=True).start()

    def _on_success(self, out_path):
        self.progress.stop()
        self.run_btn.config(state="normal", text="▶   Run Comparison")
        self._log("=" * 55, "ok")
        self.status_lbl.config(
            text=f"✅  Complete! Saved: {os.path.basename(out_path)}", fg=SUCCESS)
        if messagebox.askyesno("Done!",
                                f"Comparison complete!\n\nOutput saved to:\n{out_path}\n\nOpen the file now?"):
            self._open_file(out_path)

    def _on_error(self, err):
        self.progress.stop()
        self.run_btn.config(state="normal", text="▶   Run Comparison")
        self._log(f"ERROR: {err}", "error")
        self.status_lbl.config(text=f"❌  Error: {err}", fg=DANGER)
        messagebox.showerror("Comparison failed", err)

    def _open_file(self, path):
        import subprocess, platform
        try:
            if platform.system() == "Windows":
                os.startfile(path)
            elif platform.system() == "Darwin":
                subprocess.call(["open", path])
            else:
                subprocess.call(["xdg-open", path])
        except Exception:
            pass


