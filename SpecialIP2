"""
Excel File Comparator — GUI Version
Requires: pip install openpyxl

Run: python compare_excel_gui.py

Changes vs previous version:
  - No tkinterdnd2 dependency (browse-only, click drop zones)
  - Numeric cell differences show variance % instead of plain "Value Changed"
    e.g. OLD=100, NEW=120  →  Variance: +20.00%
  - Non-numeric differences still flagged as "Value Changed"
  - Differences sheet gains a "Variance %" column
"""

import os
import sys
import threading
import tkinter as tk
from tkinter import filedialog, messagebox
from tkinter import ttk

import openpyxl
from openpyxl import Workbook
from openpyxl.styles import PatternFill, Font, Alignment, Border, Side
from openpyxl.utils import get_column_letter
from copy import copy

# ── Excel styles ───────────────────────────────────────────────────────────

GREEN      = PatternFill("solid", start_color="C6EFCE", end_color="C6EFCE")
LIGHT_RED  = PatternFill("solid", start_color="FFCCCC", end_color="FFCCCC")
HEADER_BG  = PatternFill("solid", start_color="2F4F8F", end_color="2F4F8F")
ALT_ROW    = PatternFill("solid", start_color="F5F5F5", end_color="F5F5F5")
WHITE      = PatternFill("solid", start_color="FFFFFF", end_color="FFFFFF")

HEADER_FONT = Font(name="Arial", bold=True, color="FFFFFF", size=11)
NORMAL_FONT = Font(name="Arial", size=10)
BOLD_FONT   = Font(name="Arial", bold=True, size=10)

thin = Side(style="thin", color="CCCCCC")
THIN_BORDER = Border(left=thin, right=thin, top=thin, bottom=thin)
CENTER = Alignment(horizontal="center", vertical="center", wrap_text=True)
LEFT   = Alignment(horizontal="left",   vertical="center", wrap_text=True)


# ── Helpers ────────────────────────────────────────────────────────────────

def cell_value(ws, row, col):
    v = ws.cell(row=row, column=col).value
    return "" if v is None else v


def normalize(v):
    return v.strip() if isinstance(v, str) else v


def is_numeric(v):
    return isinstance(v, (int, float)) and not isinstance(v, bool)


def calc_variance(new_val, old_val):
    """
    Returns variance % string using (new - old) / |old| * 100.
    If old == 0 returns special string.
    """
    if old_val == 0:
        return "N/A (old=0)"
    pct = (new_val - old_val) / abs(old_val) * 100
    sign = "+" if pct >= 0 else ""
    return f"{sign}{pct:.2f}%"


def copy_cell_style(src, dst):
    for attr in ("font", "alignment", "border", "number_format"):
        val = getattr(src, attr, None)
        if val:
            if attr == "number_format":
                dst.number_format = val
            else:
                setattr(dst, attr, copy(val))


# ── Core comparison ────────────────────────────────────────────────────────

def compare_and_write(new_ws, old_ws, out_ws, differences, sheet_name):
    new_max_row = new_ws.max_row or 0
    new_max_col = new_ws.max_column or 0
    old_max_row = old_ws.max_row or 0
    old_max_col = old_ws.max_column or 0
    max_row = max(new_max_row, old_max_row)
    max_col = max(new_max_col, old_max_col)
    match_count = diff_count = only_new = only_old = 0

    for row in range(1, max_row + 1):
        for col in range(1, max_col + 1):
            new_val = cell_value(new_ws, row, col)
            old_val = cell_value(old_ws, row, col)
            out_cell = out_ws.cell(row=row, column=col)
            in_new = row <= new_max_row and col <= new_max_col
            in_old = row <= old_max_row and col <= old_max_col
            out_cell.value = new_val if in_new else old_val
            src = new_ws.cell(row=row, column=col) if in_new else old_ws.cell(row=row, column=col)
            copy_cell_style(src, out_cell)
            cell_ref = f"{get_column_letter(col)}{row}"

            if in_new and not in_old:
                out_cell.fill = LIGHT_RED
                only_new += 1; diff_count += 1
                differences.append({
                    "sheet": sheet_name, "cell": cell_ref,
                    "new_value": new_val, "old_value": "(cell does not exist)",
                    "change_type": "Added in NEW", "variance": ""
                })

            elif in_old and not in_new:
                out_cell.fill = LIGHT_RED
                only_old += 1; diff_count += 1
                differences.append({
                    "sheet": sheet_name, "cell": cell_ref,
                    "new_value": "(cell does not exist)", "old_value": old_val,
                    "change_type": "Removed in NEW", "variance": ""
                })

            elif normalize(new_val) == normalize(old_val):
                out_cell.fill = GREEN
                match_count += 1

            else:
                out_cell.fill = LIGHT_RED
                diff_count += 1

                if is_numeric(new_val) and is_numeric(old_val):
                    variance_str = calc_variance(new_val, old_val)
                    change_type  = "Numeric Variance"
                else:
                    variance_str = ""
                    change_type  = "Value Changed"

                differences.append({
                    "sheet": sheet_name, "cell": cell_ref,
                    "new_value": new_val, "old_value": old_val,
                    "change_type": change_type, "variance": variance_str
                })

    for col_letter, dim in new_ws.column_dimensions.items():
        out_ws.column_dimensions[col_letter].width = dim.width
    for row_num, dim in new_ws.row_dimensions.items():
        out_ws.row_dimensions[row_num].height = dim.height

    return match_count, diff_count, only_new, only_old


# ── Differences sheet ──────────────────────────────────────────────────────

def build_differences_sheet(wb, differences, sheet_stats):
    ws = wb.create_sheet("Differences")

    # Title
    ws.merge_cells("A1:H1")
    t = ws["A1"]
    t.value = "Excel Comparison — Differences Report"
    t.font = Font(name="Arial", bold=True, size=14, color="FFFFFF")
    t.fill = PatternFill("solid", start_color="1F3864", end_color="1F3864")
    t.alignment = CENTER
    ws.row_dimensions[1].height = 30

    # Summary
    ws["A3"] = "SUMMARY"
    ws["A3"].font = Font(name="Arial", bold=True, size=11, color="1F3864")
    for ci, h in enumerate(["Sheet Name", "Matching Cells", "Different Cells",
                             "Added (New only)", "Removed (Old only)", "Total Cells Compared"], 1):
        c = ws.cell(row=4, column=ci, value=h)
        c.font = HEADER_FONT; c.fill = HEADER_BG; c.alignment = CENTER; c.border = THIN_BORDER

    for ri, stat in enumerate(sheet_stats, 5):
        row_fill = ALT_ROW if ri % 2 == 0 else WHITE
        for ci, val in enumerate([stat["sheet"], stat["match"], stat["diff"],
                                   stat["only_new"], stat["only_old"],
                                   stat["match"] + stat["diff"]], 1):
            c = ws.cell(row=ri, column=ci, value=val)
            c.font = NORMAL_FONT; c.fill = row_fill; c.alignment = CENTER; c.border = THIN_BORDER

    totals_row = 5 + len(sheet_stats)
    ws.cell(row=totals_row, column=1, value="TOTAL").font = BOLD_FONT
    for ci, key in enumerate(["match", "diff", "only_new", "only_old"], 2):
        c = ws.cell(row=totals_row, column=ci, value=sum(s[key] for s in sheet_stats))
        c.font = BOLD_FONT
        c.fill = PatternFill("solid", start_color="D9E1F2", end_color="D9E1F2")
        c.border = THIN_BORDER; c.alignment = CENTER

    # Detailed differences table — includes Variance % column
    detail_start = totals_row + 3
    ws.cell(row=detail_start - 1, column=1, value="DETAILED DIFFERENCES").font = Font(
        name="Arial", bold=True, size=11, color="1F3864")

    detail_headers = ["#", "Sheet", "Cell", "Change Type", "Old Value", "New Value", "Variance %", "Notes"]
    for ci, h in enumerate(detail_headers, 1):
        c = ws.cell(row=detail_start, column=ci, value=h)
        c.font = HEADER_FONT; c.fill = HEADER_BG; c.alignment = CENTER; c.border = THIN_BORDER

    change_type_color = {
        "Numeric Variance": "FFCCCC",
        "Value Changed":    "FFE5CC",
        "Added in NEW":     "CCE5FF",
        "Removed in NEW":   "FFE5CC",
    }

    fmt_val = lambda v: str(v) if v not in ("", None) else "(empty)"

    for ri, diff in enumerate(differences, 1):
        er = detail_start + ri
        bg   = change_type_color.get(diff["change_type"], "FFFFFF")
        fill = PatternFill("solid", start_color=bg, end_color=bg)
        row_data = [
            ri, diff["sheet"], diff["cell"], diff["change_type"],
            fmt_val(diff["old_value"]), fmt_val(diff["new_value"]),
            diff.get("variance", ""), ""
        ]
        for ci, val in enumerate(row_data, 1):
            c = ws.cell(row=er, column=ci, value=val)
            c.font = NORMAL_FONT; c.fill = fill
            c.alignment = CENTER if ci in (1, 3, 7) else LEFT
            c.border = THIN_BORDER
            # Colour-code variance cell: green positive, red negative
            if ci == 7 and val and val not in ("N/A (old=0)", ""):
                is_pos = val.startswith("+")
                c.font = Font(name="Arial", size=10, bold=True,
                               color="16A34A" if is_pos else "DC2626")

    # Column widths
    ws.column_dimensions["A"].width = 6
    ws.column_dimensions["B"].width = 22
    ws.column_dimensions["C"].width = 10
    ws.column_dimensions["D"].width = 18
    ws.column_dimensions["E"].width = 30
    ws.column_dimensions["F"].width = 30
    ws.column_dimensions["G"].width = 14
    ws.column_dimensions["H"].width = 22

    # Legend
    legend_row = detail_start + len(differences) + 3
    ws.cell(row=legend_row, column=1, value="LEGEND").font = BOLD_FONT
    legend_items = [
        (GREEN,      "Cells match between NEW and OLD"),
        (LIGHT_RED,  "Numeric variance — % change shown in Variance % column"),
        (PatternFill("solid", start_color="FFE5CC", end_color="FFE5CC"),
         "Text/non-numeric value changed, or cell removed"),
        (PatternFill("solid", start_color="CCE5FF", end_color="CCE5FF"),
         "Cell exists in NEW only (added)"),
    ]
    for i, (fill, label) in enumerate(legend_items):
        r = legend_row + 1 + i
        c = ws.cell(row=r, column=1, value="  ")
        c.fill = fill; c.border = THIN_BORDER
        ws.cell(row=r, column=2, value=label).font = NORMAL_FONT

    ws.freeze_panes = ws.cell(row=detail_start + 1, column=1)


# ── Orchestrator ───────────────────────────────────────────────────────────

def run_comparison(new_path, old_path, out_path, log_fn):
    log_fn("Loading workbooks…")
    new_wb = openpyxl.load_workbook(new_path, data_only=True)
    old_wb = openpyxl.load_workbook(old_path, data_only=True)
    out_wb = Workbook()
    out_wb.remove(out_wb.active)

    new_sheets = set(new_wb.sheetnames)
    old_sheets = set(old_wb.sheetnames)
    all_sheets = list(new_wb.sheetnames)
    for s in old_wb.sheetnames:
        if s not in new_sheets:
            all_sheets.append(s)

    differences = []
    sheet_stats = []

    for sheet_name in all_sheets:
        log_fn(f"  Comparing: {sheet_name}")
        out_ws = out_wb.create_sheet(title=sheet_name)

        if sheet_name in new_sheets and sheet_name in old_sheets:
            m, d, on, oo = compare_and_write(
                new_wb[sheet_name], old_wb[sheet_name], out_ws, differences, sheet_name)

        elif sheet_name in new_sheets:
            nws = new_wb[sheet_name]
            for row in nws.iter_rows():
                for cell in row:
                    oc = out_ws.cell(row=cell.row, column=cell.column, value=cell.value)
                    oc.fill = LIGHT_RED; copy_cell_style(cell, oc)
                    if cell.value not in (None, ""):
                        differences.append({
                            "sheet": sheet_name, "cell": cell.coordinate,
                            "new_value": cell.value, "old_value": "(sheet not in OLD)",
                            "change_type": "Added in NEW", "variance": ""
                        })
            m, d, on, oo = (0, (nws.max_row or 0) * (nws.max_column or 0),
                            (nws.max_row or 0) * (nws.max_column or 0), 0)

        else:
            ows = old_wb[sheet_name]
            for row in ows.iter_rows():
                for cell in row:
                    oc = out_ws.cell(row=cell.row, column=cell.column, value=cell.value)
                    oc.fill = LIGHT_RED; copy_cell_style(cell, oc)
                    if cell.value not in (None, ""):
                        differences.append({
                            "sheet": sheet_name, "cell": cell.coordinate,
                            "new_value": "(sheet not in NEW)", "old_value": cell.value,
                            "change_type": "Removed in NEW", "variance": ""
                        })
            m, d, on, oo = (0, (ows.max_row or 0) * (ows.max_column or 0),
                            0, (ows.max_row or 0) * (ows.max_column or 0))

        sheet_stats.append({"sheet": sheet_name, "match": m, "diff": d,
                             "only_new": on, "only_old": oo})

    log_fn("Building Differences sheet…")
    build_differences_sheet(out_wb, differences, sheet_stats)
    out_wb.save(out_path)

    total_diff  = sum(s["diff"]  for s in sheet_stats)
    total_match = sum(s["match"] for s in sheet_stats)
    log_fn(f"✅  Done!  Matching: {total_match}  |  Different: {total_diff}  |  Total diffs logged: {len(differences)}")
    log_fn(f"📄  Saved to: {out_path}")
    return total_match, total_diff, len(differences)


