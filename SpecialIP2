class DropZone(tk.Frame):
    """Clickable file-picker zone (no drag-and-drop required)."""

    def __init__(self, parent, label, color_tag, on_file_set=None, **kwargs):
        super().__init__(parent, bg=CARD_BG, bd=0, **kwargs)
        self.label       = label
        self.color_tag   = color_tag
        self.on_file_set = on_file_set
        self._file_path  = ""
        self._build()

    def _build(self):
        self.border_frame = tk.Frame(self, bg=BORDER_CLR, padx=1, pady=1)
        self.border_frame.pack(fill="both", expand=True)

        self.inner = tk.Frame(self.border_frame, bg=DROP_IDLE, cursor="hand2")
        self.inner.pack(fill="both", expand=True)

        tag_colors = {"new": ("#DCFCE7", "#16A34A"), "old": ("#FEF3C7", "#D97706")}
        tag_bg, tag_fg = tag_colors.get(self.color_tag, ("#EFF6FF", ACCENT))

        tag_frame = tk.Frame(self.inner, bg=DROP_IDLE)
        tag_frame.pack(pady=(18, 0))
        tk.Label(tag_frame, text=f"  {self.label}  ", bg=tag_bg, fg=tag_fg,
                 font=("Segoe UI", 9, "bold"), padx=6, pady=3).pack()

        tk.Label(self.inner, text="📂", font=("Segoe UI", 28),
                 bg=DROP_IDLE, fg=TEXT_SUB).pack(pady=(8, 4))

        self.prompt_lbl = tk.Label(self.inner, text="Click to browse for file",
                                    font=FONT_SMALL, bg=DROP_IDLE, fg=TEXT_SUB,
                                    justify="center")
        self.prompt_lbl.pack()

        self.file_lbl = tk.Label(self.inner, text="",
                                  font=("Segoe UI", 9, "bold"),
                                  bg=DROP_IDLE, fg=SUCCESS,
                                  wraplength=220, justify="center")
        self.file_lbl.pack(pady=(6, 14))

        for w in (self.inner, self.prompt_lbl, self.file_lbl):
            w.bind("<Button-1>", lambda e: self._browse())
            w.bind("<Enter>",    lambda e: self._hover(True))
            w.bind("<Leave>",    lambda e: self._hover(False))

    def _hover(self, entering):
        if not self._file_path:
            bg = "#DBEAFE" if entering else DROP_IDLE
            self.inner.config(bg=bg)
            for w in (self.prompt_lbl, self.file_lbl):
                w.config(bg=bg)

    def _browse(self):
        path = filedialog.askopenfilename(
            title=f"Select {self.label} file",
            filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")])
        if path:
            self.set_file(path)

    def set_file(self, path):
        self._file_path = path
        self.file_lbl.config(text=f"✓  {os.path.basename(path)}")
        self.prompt_lbl.config(text="Click to change file")
        for w in (self.inner, self.prompt_lbl, self.file_lbl):
            w.config(bg=DROP_READY)
        self.border_frame.config(bg=SUCCESS)
        if self.on_file_set:
            self.on_file_set()

    def get_file(self):
        return self._file_path

    def clear(self):
        self._file_path = ""
        self.file_lbl.config(text="")
        self.prompt_lbl.config(text="Click to browse for file")
        for w in (self.inner, self.prompt_lbl, self.file_lbl):
            w.config(bg=DROP_IDLE)
        self.border_frame.config(bg=BORDER_CLR)


class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Excel File Comparator")
        self.resizable(False, False)
        self.configure(bg=BG)
        self._build_ui()
        self._center()

    def _center(self):
        self.update_idletasks()
        w, h = self.winfo_width(), self.winfo_height()
        sw, sh = self.winfo_screenwidth(), self.winfo_screenheight()
        self.geometry(f"+{(sw - w) // 2}+{(sh - h) // 2}")

    def _card(self, parent, **kw):
        return tk.Frame(parent, bg=CARD_BG, padx=20, pady=16, **kw)

    def _build_ui(self):
        # Header
        hdr = tk.Frame(self, bg=ACCENT, pady=20)
        hdr.pack(fill="x")
        tk.Label(hdr, text="Excel File Comparator", font=FONT_H1,
                 bg=ACCENT, fg="white").pack()
        tk.Label(hdr,
                 text="Compare two workbooks cell-by-cell  •  Numeric differences shown as variance %",
                 font=FONT_SMALL, bg=ACCENT, fg="#BFDBFE").pack(pady=(4, 0))

        body = tk.Frame(self, bg=BG, padx=24, pady=20)
        body.pack(fill="both", expand=True)

        # Drop zones
        drop_row = tk.Frame(body, bg=BG)
        drop_row.pack(fill="x")

        self.new_zone = DropZone(drop_row, "NEW FILE", "new",
                                  on_file_set=self._check_ready, width=250, height=200)
        self.new_zone.pack(side="left", fill="both", expand=True, padx=(0, 8))

        vs = tk.Frame(drop_row, bg=BG, width=44)
        vs.pack(side="left")
        vs.pack_propagate(False)
        tk.Label(vs, text="VS", font=("Segoe UI", 14, "bold"),
                 bg=BG, fg=BORDER_CLR).place(relx=0.5, rely=0.5, anchor="center")

        self.old_zone = DropZone(drop_row, "OLD FILE", "old",
                                  on_file_set=self._check_ready, width=250, height=200)
        self.old_zone.pack(side="left", fill="both", expand=True, padx=(8, 0))

        # Output path info
        info_frame = tk.Frame(body, bg=BG)
        info_frame.pack(fill="x", pady=(14, 0))
        tk.Label(info_frame, text="📁  Output folder:", font=FONT_SMALL,
                 bg=BG, fg=TEXT_SUB).pack(side="left")
        script_dir = os.path.dirname(os.path.abspath(sys.argv[0])) or os.getcwd()
        tk.Label(info_frame, text=script_dir,
                 font=("Segoe UI", 9, "italic"), bg=BG, fg=ACCENT).pack(side="left", padx=(4, 0))

        # Buttons
        btn_frame = tk.Frame(body, bg=BG)
        btn_frame.pack(pady=(18, 0))

        self.run_btn = tk.Button(btn_frame, text="▶   Run Comparison",
                                  font=("Segoe UI", 12, "bold"),
                                  bg=ACCENT, fg="white",
                                  activebackground=ACCENT_DARK, activeforeground="white",
                                  relief="flat", padx=36, pady=12,
                                  cursor="hand2", state="disabled",
                                  command=self._start_comparison)
        self.run_btn.pack(side="left", padx=(0, 10))

        self.clear_btn = tk.Button(btn_frame, text="✕  Clear",
                                    font=FONT_BODY, bg="#F1F5F9", fg=TEXT_SUB,
                                    activebackground="#E2E8F0", activeforeground=TEXT_MAIN,
                                    relief="flat", padx=18, pady=12,
                                    cursor="hand2", command=self._clear)
        self.clear_btn.pack(side="left")

        # Progress bar
        self.progress = ttk.Progressbar(body, mode="indeterminate", length=520)
        self.progress.pack(pady=(14, 0))
        ttk.Style().configure("TProgressbar", troughcolor=BORDER_CLR, background=ACCENT)

        # Log panel
        log_card = self._card(body)
        log_card.pack(fill="both", expand=True, pady=(14, 0))
        tk.Label(log_card, text="Log", font=FONT_H2, bg=CARD_BG, fg=TEXT_MAIN).pack(anchor="w")
        log_inner = tk.Frame(log_card, bg=CARD_BG)
        log_inner.pack(fill="both", expand=True, pady=(6, 0))
        self.log_text = tk.Text(log_inner, height=10, font=FONT_MONO,
                                 bg="#0F172A", fg="#94A3B8",
                                 insertbackground="white", relief="flat",
                                 state="disabled", wrap="word")
        scroll = tk.Scrollbar(log_inner, command=self.log_text.yview)
        self.log_text.config(yscrollcommand=scroll.set)
        scroll.pack(side="right", fill="y")
        self.log_text.pack(fill="both", expand=True)
        self.log_text.tag_config("ok",    foreground="#4ADE80")
        self.log_text.tag_config("info",  foreground="#94A3B8")
        self.log_text.tag_config("warn",  foreground="#FCD34D")
        self.log_text.tag_config("error", foreground="#F87171")

        # Status bar
        tk.Frame(self, bg=BORDER_CLR, height=1).pack(fill="x")
        self.status_lbl = tk.Label(self,
                                    text="Ready — select a NEW file and an OLD file to begin",
                                    font=FONT_SMALL, bg=BG, fg=TEXT_SUB, pady=6)
        self.status_lbl.pack(fill="x")

    # ── Helpers ───────────────────────────────────────────────────────────

    def _check_ready(self):
        both = bool(self.new_zone.get_file() and self.old_zone.get_file())
        self.run_btn.config(state="normal" if both else "disabled",
                             bg=ACCENT if both else "#93C5FD")

    def _clear(self):
        self.new_zone.clear(); self.old_zone.clear()
        self.run_btn.config(state="disabled", bg="#93C5FD")
        self._log("Cleared.", "info")
        self.status_lbl.config(
            text="Ready — select a NEW file and an OLD file to begin", fg=TEXT_SUB)

    def _log(self, msg, tag="info"):
        self.log_text.config(state="normal")
        self.log_text.insert("end", msg + "\n", tag)
        self.log_text.see("end")
        self.log_text.config(state="disabled")

    def _start_comparison(self):
        new_path = self.new_zone.get_file()
        old_path = self.old_zone.get_file()
        if not new_path or not old_path:
            messagebox.showwarning("Missing files", "Please select both NEW and OLD Excel files.")
            return

        script_dir = os.path.dirname(os.path.abspath(sys.argv[0])) or os.getcwd()
        out_path   = os.path.join(script_dir, "comparison_output.xlsx")

        self.run_btn.config(state="disabled", text="⏳  Running…")
        self.progress.start(12)
        self.status_lbl.config(text="Comparing files…", fg=ACCENT)
        self._log(f"NEW : {new_path}", "info")
        self._log(f"OLD : {old_path}", "info")
        self._log(f"OUT : {out_path}", "info")
        self._log("─" * 55, "info")

        def worker():
            try:
                run_comparison(new_path, old_path, out_path,
                               lambda m: self.after(0, self._log, m, "info"))
                self.after(0, self._on_success, out_path)
            except Exception as e:
                self.after(0, self._on_error, str(e))

        threading.Thread(target=worker, daemon=True).start()

    def _on_success(self, out_path):
        self.progress.stop()
        self.run_btn.config(state="normal", text="▶   Run Comparison")
        self._log("=" * 55, "ok")
        self.status_lbl.config(
            text=f"✅  Complete! Saved: {os.path.basename(out_path)}", fg=SUCCESS)
        if messagebox.askyesno("Done!",
                                f"Comparison complete!\n\nOutput saved to:\n{out_path}\n\nOpen the file now?"):
            self._open_file(out_path)

    def _on_error(self, err):
        self.progress.stop()
        self.run_btn.config(state="normal", text="▶   Run Comparison")
        self._log(f"ERROR: {err}", "error")
        self.status_lbl.config(text=f"❌  Error: {err}", fg=DANGER)
        messagebox.showerror("Comparison failed", err)

    def _open_file(self, path):
        import subprocess, platform
        try:
            if platform.system() == "Windows":
                os.startfile(path)
            elif platform.system() == "Darwin":
                subprocess.call(["open", path])
            else:
                subprocess.call(["xdg-open", path])
        except Exception:
            pass


if __name__ == "__main__":
    App().mainloop()
