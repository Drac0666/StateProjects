from openpyxl.chart.shapes import GraphicalProperties
from lxml import etree

NS = "http://schemas.openxmlformats.org/drawingml/2006/main"

def _apply_no_fill(spPr):
    fill_tags = [
        f"{{{NS}}}noFill", f"{{{NS}}}solidFill",
        f"{{{NS}}}gradFill", f"{{{NS}}}pattFill",
    ]
    for child in list(spPr):
        if child.tag in fill_tags:
            spPr.remove(child)
    etree.SubElement(spPr, f"{{{NS}}}noFill")


def add_line_chart(ws, col_indices, title, anchor):
    chart = LineChart()
    chart.title = title
    chart.style = 10
    chart.grouping = "standard"
    chart.width = 20
    chart.height = 12

    min_row = 1
    max_row = ws.max_row

    x_col = col_indices[0]
    categories = Reference(ws, min_col=x_col, min_row=min_row + 1, max_row=max_row)
    chart.set_categories(categories)

    for col in col_indices[1:]:
        data = Reference(ws, min_col=col, min_row=min_row, max_row=max_row)
        chart.add_data(data, titles_from_data=True)

    chart.x_axis.title = ws.cell(row=min_row, column=x_col).value or "X Axis"
    chart.x_axis.tickLblPos = "low"
    chart.x_axis.delete = False

    chart.y_axis.title = "Value"
    chart.y_axis.delete = False
    chart.y_axis.scaling.min = 2000
    chart.y_axis.scaling.max = 4000
    chart.y_axis.numFmt = "#,##0"

    chart.legend.position = "b"

    # ---- no fill ----
    if chart.spPr is None:
        chart.spPr = GraphicalProperties()
    _apply_no_fill(chart.spPr._element)

    if chart.plot_area.spPr is None:
        chart.plot_area.spPr = GraphicalProperties()
    _apply_no_fill(chart.plot_area.spPr._element)
    # -----------------

    chart.anchor = anchor
    ws.add_chart(chart)
